---
profile: production

exclude_paths:
  - .github/
  - .git/
  - tests/
  - playbook.yml  # Example playbook with non-standard format
  - client.yml    # Example playbook with non-standard format

skip_list:
  - var-naming[no-role-prefix]  # Allow variables without role prefix for backwards compatibility
  - yaml[comments]  # Skip comment spacing rules in defaults/main.yml
  - yaml[comments-indentation]  # Skip comment indentation rules
  - yaml[document-start]  # Skip document start requirement
  - yaml[truthy]    # Skip truthy value rules for backwards compat
  - jinja[spacing]  # Skip Jinja2 spacing rules
  - no-changed-when # Skip changed_when requirements (too strict for some commands)
  - name[template]  # Skip template in name rules
  - command-instead-of-shell  # Allow shell when needed
  - risky-shell-pipe  # Allow pipes in shell commands
  - key-order[task]  # Allow flexible task key ordering

warn_list:
  - experimental
  - role-name[path]

enable_list:
  - yaml
